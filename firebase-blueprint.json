{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and wallet balance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "username": { "type": "string" },
        "phone": { "type": "string" },
        "walletBalance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "referralCode": { "type": "string" },
        "referralCount": { "type": "number" },
        "referralEarnings": { "type": "number" },
        "referredBy": { "type": "string" },
        "isPinSet": { "type": "boolean" },
        "transactionPin": { "type": "string" },
        "isProfileComplete": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "virtualAccount": {
          "type": "object",
          "properties": {
            "account_name": { "type": "string" },
            "account_number": { "type": "string" },
            "bank_id": { "type": "string" },
            "bank_name": { "type": "string" },
            "reference": { "type": "string" }
          }
        },
        "dataBeneficiaries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "phone": { "type": "string" },
              "network": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "email", "walletBalance", "role"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Records of all financial activities.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "reference": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "status", "createdAt"]
    },
    "ScheduledPurchase": {
      "title": "Scheduled Purchase",
      "description": "Automated recurring bill payments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "frequency": { "type": "string" },
        "nextRun": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "frequency", "nextRun"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "siteDescription": { "type": "string" },
        "announcement": { "type": "string" },
        "referralBonus": { "type": "number" },
        "resellerUpgradeFee": { "type": "number" },
        "smartUserPackageName": { "type": "string" },
        "resellerPackageName": { "type": "string" },
        "heroImage": { "type": "string" },
        "fastDeliveryImage": { "type": "string" },
        "resellerImage": { "type": "string" },
        "developerImage": { "type": "string" },
        "fundingImage": { "type": "string" },
        "supportImage": { "type": "string" },
        "supportedLogos": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "createdAt"]
    },
    "PriceSetting": {
      "title": "Price Setting",
      "description": "Service pricing and discounts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceType": { "type": "string" },
        "network": { "type": "string" },
        "planName": { "type": "string" },
        "userPrice": { "type": "number" },
        "resellerPrice": { "type": "number" },
        "resellerDiscount": { "type": "number" },
        "profitMargin": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transaction logs."
    },
    "/scheduled_purchases/{purchaseId}": {
      "schema": "ScheduledPurchase",
      "description": "Scheduled bill payments."
    },
    "/settings/{settingId}": {
      "schema": "AppSettings",
      "description": "Global settings."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications."
    },
    "/prices/{priceId}": {
      "schema": "PriceSetting",
      "description": "Service pricing."
    }
  }
}
