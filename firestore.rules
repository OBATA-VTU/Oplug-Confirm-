rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow admins full read access to everything
    match /{allPaths=**} {
      allow read: if isAdmin();
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - id: string (required)
    //   - email: string (required, email format)
    //   - walletBalance: number (required)
    //   - role: string (required, 'user' | 'reseller' | 'admin')
    //   - username: string (required)
    //   - firstName: string (required)
    //   - lastName: string (required)
    //   - phone: string (required)
    //   - transactionPin: string (optional)
    //   - isPinSet: boolean (optional)
    //   - virtualAccount: map (optional)
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - userId: string (required)
    //   - amount: number (required)
    //   - type: string (required)
    //   - status: string (required)
    //   - description: string (required)
    //   - reference: string (required)
    //   - profit: number (optional, for resellers)
    //   - service: string (optional, e.g., 'data', 'airtime')
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document ID: {settingId}
    //
    // Collection: manual_payments
    // Document ID: {paymentId}
    // Fields:
    //   - userId: string (required)
    //   - amount: number (required)
    //   - proofUrl: string (required)
    //   - status: string (required, 'pending' | 'approved' | 'rejected')
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "samyjkr36@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'walletBalance', 'role', 'username', 'firstName', 'lastName', 'phone']) &&
             data.id is string &&
             data.email is string &&
             data.walletBalance is number &&
             data.role in ['user', 'reseller', 'admin'] &&
             data.username is string &&
             data.firstName is string &&
             data.lastName is string &&
             data.phone is string;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'status', 'description', 'reference', 'createdAt']) &&
             data.userId is string &&
             data.amount is number &&
             data.type is string &&
             data.status is string &&
             data.description is string &&
             data.reference is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Allow individual read for owner or admin
      // Allow listing only for admins
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && 
                       // Prevent self-escalation to admin
                       (request.resource.data.role == resource.data.role || (resource.data.role == 'user' && request.resource.data.role == 'reseller')) &&
                       // Prevent self-balance modification (should be done via server/transactions)
                       // EXCEPT when upgrading (balance is decremented)
                       (request.resource.data.walletBalance == resource.data.walletBalance || (request.resource.data.walletBalance < resource.data.walletBalance && request.resource.data.role == 'reseller'))
                       ) || 
                       isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidTransaction(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /manual_payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /vtu_services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /smm_services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cache/{cacheId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /otps/{email} {
      allow read, write: if true;
    }

    match /health_check/{docId} {
      allow read, write: if true;
    }
  }
}
